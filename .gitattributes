# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Go files
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Documentation
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Makefile
Makefile text eol=lf
